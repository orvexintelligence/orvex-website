# ═══════════════════════════════════════════════════════════════
#  ORVEX Breach & Identity Shield — Variabili d'ambiente
#
#  1. Copia questo file in .env.local (nella root del progetto)
#  2. Sostituisci i placeholder con i tuoi Payment Links Stripe
#  3. .env.local è in .gitignore → NON viene committato
#
#  Dove trovare i Payment Links:
#  Stripe Dashboard → Payments → Payment Links → [tuo link] → Copy
# ═══════════════════════════════════════════════════════════════

# ── Stripe Payment Links — EUR ─────────────────────────────────
VITE_STRIPE_MONTHLY_EUR=https://buy.stripe.com/SOSTITUISCI_QUI
VITE_STRIPE_ANNUAL_EUR=https://buy.stripe.com/SOSTITUISCI_QUI

# ── Stripe Payment Links — USD ─────────────────────────────────
VITE_STRIPE_MONTHLY_USD=https://buy.stripe.com/SOSTITUISCI_QUI
VITE_STRIPE_ANNUAL_USD=https://buy.stripe.com/SOSTITUISCI_QUI

# ── URL dell'app (usato come success_url in Stripe) ────────────
# Configura in OGNI Payment Link di Stripe:
#   After payment → redirect to → VITE_APP_URL?paid=identity
#   oppure  ?paid=domain   (Domain Watch)
#   oppure  ?paid=api      (API Integration)
VITE_APP_URL=http://localhost:5173

# ── Backend API ────────────────────────────────────────────────
# In locale lascia vuoto se usi Vite proxy; in produzione imposta il dominio API.
# Esempio: https://app.orvexintelligence.com oppure https://orvex-breach-shield-api.onrender.com
VITE_API_BASE_URL=

# ── Backend / Have I Been Pwned ────────────────────────────────
HIBP_API_KEY=
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.orvexintelligence.com

# ── Limite scansioni gratuite lato server ─────────────────────
ENFORCE_FREE_SCAN_LIMIT=true
FREE_SCAN_LIMIT=1
FREE_SCAN_WINDOW_HOURS=24

# Link usato dal backend quando risponde 402 Payment Required
IDENTITY_PAYMENT_URL=https://buy.stripe.com/SOSTITUISCI_QUI
DOMAIN_PAYMENT_URL=https://buy.stripe.com/SOSTITUISCI_DOMAIN_WATCH

# Provider usato dal backend per il motore Domain Watch reale
DOMAIN_SCAN_PROVIDER_URL=https://orvex-server.onrender.com/api/domain/scan

# Solo sviluppo locale: se true permette risultati demo quando il backend non risponde.
# Non usarlo in produzione.
VITE_ALLOW_MOCK_FALLBACK=false
