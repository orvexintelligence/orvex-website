# ═══════════════════════════════════════════════════════════════
#  ORVEX Breach & Identity Shield — Variabili d'ambiente
#
#  1. Copia questo file in .env.local (nella root del progetto)
#  2. Sostituisci i placeholder con i tuoi Payment Links Stripe
#  3. .env.local è in .gitignore → NON viene committato
#
#  Dove trovare i Payment Links:
#  Stripe Dashboard → Payments → Payment Links → [tuo link] → Copy
# ═══════════════════════════════════════════════════════════════

# ── Stripe Payment Links — EUR ─────────────────────────────────
VITE_STRIPE_MONTHLY_EUR=https://buy.stripe.com/SOSTITUISCI_QUI
VITE_STRIPE_ANNUAL_EUR=https://buy.stripe.com/SOSTITUISCI_QUI

# ── Stripe Payment Links — USD ─────────────────────────────────
VITE_STRIPE_MONTHLY_USD=https://buy.stripe.com/SOSTITUISCI_QUI
VITE_STRIPE_ANNUAL_USD=https://buy.stripe.com/SOSTITUISCI_QUI

# ── URL dell'app (usato come success_url in Stripe) ────────────
# Configura in OGNI Payment Link di Stripe:
#   After payment → redirect to → VITE_APP_URL?paid=identity
#   oppure  ?paid=domain   (Domain Watch)
#   oppure  ?paid=api      (API Integration)
VITE_APP_URL=http://localhost:5173
